# Jarvis Environment Configuration
# Copy this to .env and fill in your values

# Ollama Cloud API Key (from ollama.com/settings/keys)
OLLAMA_API_KEY=your_ollama_api_key_here

# Google Gemini API Key (from aistudio.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override Ollama host (defaults to https://ollama.com)
# OLLAMA_HOST=https://ollama.com

# Optional: Override model names
# OLLAMA_MODEL=gemma4
# GEMINI_MODEL=gemini-2.5-flash

# Optional: How Jarvis addresses you (default: Sir)
# JARVIS_USER_NAME=Sir
